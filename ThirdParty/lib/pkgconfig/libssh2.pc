prefix=/Users/steve/Documents/GitHub/MacSSH/ThirdParty
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libssh2
URL: https://libssh2.org/
Description: Library for SSH-based communication
Version: 1.11.2_DEV
Requires: libcrypto,zlib
Requires.private: libcrypto,zlib
Libs: -L${libdir} -lssh2 -lcrypto -lz
Libs.private: -lcrypto -lz
Cflags: -I${includedir}
