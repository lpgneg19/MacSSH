# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Xcode
# .xcodeproj and .xcworkspace are generated by xcodegen, so they are not needed in git
*.xcodeproj/
*.xcworkspace/
build/
DerivedData/
.DerivedData/
*.hmap
*.ipa
*.xcuserstate
xcuserdata/
*.xccheckout
*.moved-aside
*.qlresults
*.hmap
*.ipa
*.pbproj
*.pbxuser

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved

# Logs and temporary files
*.log
*.swp
*.swo

# ThirdParty Dependencies
# Ignore the source code and build artifacts of dependencies (very large)
ThirdParty/src/
ThirdParty/build/

# Keep only the compiled libraries and headers if you want others to build immediately
# Alternatively, use scripts to build them locally.
# ThirdParty/lib/
# ThirdParty/include/

# Misc
*.swiftmodule
*.swiftdoc
*.swiftinterface
.idea/
.vscode/
.gemini/
